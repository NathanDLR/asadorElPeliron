---
import "../styles/global.css";
import { menus, articles } from "../data/menu";

const formatPrice = (price: number) =>
  price.toLocaleString("es-ES", { style: "currency", currency: "EUR" });
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Carta de Asador El Pelirón" />
    <title>Carta — Asador El Pelirón</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <p class="site-eyebrow">Asador</p>
        <h1 class="site-title">El Pelirón</h1>
        <p class="site-tagline">Carta</p>
      </div>
    </header>

    <main class="container">
      <!-- Menus section -->
      <section class="section">
        <h2 class="section-title">Menús</h2>
        <div class="menu-grid">
          {
            menus.map((menu) => (
              <article class="menu-card">
                <div class="menu-card__header">
                  <h3 class="menu-card__name">{menu.name}</h3>
                  <span class="menu-card__price">{formatPrice(menu.price)}</span>
                </div>
                <p class="menu-card__description">{menu.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Articles section -->
      <section class="section">
        <h2 class="section-title">Artículos</h2>
        <ul class="article-list">
          {
            articles.map((article) => (
              <li class="article-item">{article.name}</li>
            ))
          }
        </ul>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Asador El Pelirón</p>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Layout */
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .site-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
    text-align: center;
  }

  .site-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
  }

  .site-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .site-tagline {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* Sections */
  .section {
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 2rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Menu cards */
  .menu-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  @media (min-width: 600px) {
    .menu-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .menu-card {
    background-color: var(--color-surface);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .menu-card__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .menu-card__name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .menu-card__price {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .menu-card__description {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.55;
  }

  /* Article list */
  .article-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  @media (min-width: 600px) {
    .article-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  .article-item {
    padding: 1rem 1.5rem;
    font-size: 0.9rem;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface);
  }

  .article-item:last-child {
    border-bottom: none;
  }

  /* Footer */
  .site-footer {
    margin-top: 5rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-muted);
  }
</style>
