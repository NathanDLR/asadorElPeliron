---
import "../styles/global.css";
import { menus, articles } from "../data/menu";
import Carousel from "../components/Carousel.astro";

const formatPrice = (price: number) =>
  price.toLocaleString("es-ES", { style: "currency", currency: "EUR" });
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Carta de Asador El Pelirón" />
    <title>Carta — Asador El Pelirón</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <p class="site-eyebrow">Asador</p>
        <h1 class="site-title">El Pelirón</h1>
        <p class="site-tagline">Carta</p>
      </div>
    </header>

    <main class="container">
      <!-- Carousel section -->
      <section class="section" style="margin-top: 2rem;">
        <h2 class="section-title">Nuestros Productos</h2>
        <Carousel />
      </section>

      <!-- Menus section -->
      <section class="section">
        <h2 class="section-title"><i>Menús</i></h2>
        <div class="menu-grid">
          {
            menus.map((menu) => (
              <article class="menu-card">
                <div class="menu-card__header">
                  <h3 class="menu-card__name">{menu.name}</h3>
                  <span class="menu-card__price">
                    {formatPrice(menu.price)}
                  </span>
                </div>
                <p class="menu-card__description">{menu.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Articles section -->
      <section class="section">
        <h2 class="section-title"><i>Artículos</i></h2>
        <div class="articles-container">
          {
            Array.from(new Set(articles.map((a) => a.category))).map(
              (category) => (
                <div class="article-category-group">
                  <h3 class="article-category-title">{category}</h3>
                  <ul class="article-list">
                    {articles
                      .filter((a) => a.category === category)
                      .map((article) => (
                        <li class="article-item">
                          <span class="article-item__name">{article.name}</span>
                          {article.price && (
                            <span class="article-item__price">
                              {formatPrice(article.price)}
                            </span>
                          )}
                        </li>
                      ))}
                  </ul>
                </div>
              ),
            )
          }
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-info">
        <p>
          Ronda El Pelirón, 49, Jerez de la Frontera | Teléfono:
          <a href="tel:956067973">956 06 79 73</a> -
          <a href="tel:655836074">655 83 60 74</a>
        </p>
        <p>Horario: Lunes a Domingo (Martes cerrado) de 09:00H a 16:00H</p>
        <p class="copyright">
          &copy; {new Date().getFullYear()} Asador El Pelirón
        </p>
      </div>
    </footer>
  </body>
</html>
